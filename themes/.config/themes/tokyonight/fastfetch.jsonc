{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",

   "logo": {
    "type": "file",
    "source": "~/dotfiles/fastfetch/.config/fastfetch/vnm-ascii.txt",
    "padding": {
      "top":9,
      "left": 1
    },
    "color": {
      "1": "38;2;118;158;234",
      "2": "38;2;118;158;234"
    }
  },

  "display": {
    "separator": " -- ",
    "color": {
      "keys": "38;2;118;158;234",
      "title": "38;2;118;158;234"
    }
  },

  "modules": [
    "title",
    "separator",

    // ───── HARDWARE ─────
    {
      "type": "custom",
      "format": "\u001b[97mHARDWARE\u001b[0m"
    },
    {
      "type": "host",
      "key": "├  PC",
      "keyColor": "38;2;118;158;234"
    },
    {
      "type": "cpu",
      "key": "├  CPU",
      "keyColor": "38;2;118;158;234"
    },
    {
      "type": "gpu",
      "key": "├ 󰍛 GPU",
      "keyColor": "38;2;118;158;234"
    },
    {
      "type": "display",
      "key": "├  Display",
      "keyColor": "38;2;118;158;234"
    },
    {
      "type": "memory",
      "key": "├  RAM",
      "format": "{used} / {total} ({percentage})",
      "keyColor": "38;2;118;158;234"
    },
    {
      "type": "disk",
      "key": "├  Disk",
      "folders": "/",
      "keyColor": "38;2;118;158;234"
    },
    {
      "type": "swap",
      "key": "└ 󰾴 Swap",
      "keyColor": "38;2;118;158;234"
    },

    // ───── SOFTWARE ─────
    {
      "type": "custom",
      "format": "\u001b[97mSOFTWARE\u001b[0m"
    },
    {
      "type": "os",
      "key": "├  OS",
      "keyColor": "38;2;118;158;234"
    },
    {
      "type": "kernel",
      "key": "├  Kernel",
      "keyColor": "38;2;118;158;234"
    },
    {
      "type": "de",
      "key": "├   DE",
      "keyColor": "38;2;118;158;234"
    },
    {
      "type": "wm",
      "key": "├  WM",
      "keyColor": "38;2;118;158;234"
    },
    {
      "type": "terminal",
      "key": "├  Terminal",
      "keyColor": "38;2;118;158;234"
    },
    {
      "type": "packages",
      "key": "├  Packages",
      "keyColor": "38;2;118;158;234"
    },
    {
      "type": "icons",
      "key": "├  Icons",
      "keyColor": "38;2;118;158;234"
    },
    {
      "type": "font",
      "key": "└  Font",
      "keyColor": "38;2;118;158;234"
    },

    // ───── AGE / UPTIME ─────
    {
      "type": "custom",
      "format": "\u001b[97mAGE / UPTIME\u001b[0m"
    },
    {
      "type": "command",
      "key": "├ 󰅐 OS Age",
      "keyColor": "38;2;118;158;234",
       "text": "echo \"$(( ($(date +%s) - $(date -d '2026-05-20 15:03:32' +%s)) / 86400 )) days\"",
    },
    {
      "type": "uptime",
      "key": "└  Uptime",
      "keyColor": "38;2;118;158;234"
    },

    "colors"
  ]
}

